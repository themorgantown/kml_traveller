# Copy this file to .env and replace with your actual API key

# OpenRouteService API Key (for run.py)
# Get a free key at: https://openrouteservice.org/dev/#/signup
# Free tier: ~1,000 geocodes/day, 500 matrix/day, 2,000 directions/day
ORS_API_KEY=your-openrouteservice-api-key-here

# Optional Configuration
CACHE_DURATION_DAYS=30
MAX_REASONABLE_DISTANCE=200000
